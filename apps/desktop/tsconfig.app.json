{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "@/*": ["./src/*"],
      "@lifehacker/core": ["../../packages/core/src"],
      "@lifehacker/core/*": ["../../packages/core/src/*"],
      "@lifehacker/storage": ["../../packages/storage/src"],
      "@lifehacker/storage/*": ["../../packages/storage/src/*"],
      "@lifehacker/ai": ["../../packages/ai/src"],
      "@lifehacker/ai/*": ["../../packages/ai/src/*"],
      "@lifehacker/plugins": ["../../packages/plugins/src"],
      "@lifehacker/plugins/*": ["../../packages/plugins/src/*"]
    }
  },
  "include": ["src"]
}
